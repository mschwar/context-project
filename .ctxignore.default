# Default ignore patterns for ctx
# These are always applied. Users can add more via .ctxignore in their project root.

# Version control
.git/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.eggs/
*.egg-info/
dist/
build/

# Node.js
node_modules/
.npm/
.yarn/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.obsidian/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Environment / secrets
.env
.env.*
*.pem
*.key

# ctx output (don't index your own manifests)
CONTEXT.md

# Large binary formats (still listed as [binary] in manifests, but not sent to LLM)
# These are NOT ignored from listing — they're just noted. This section is for
# files/dirs to skip entirely.
