# Default ignore patterns for ctx
# These are always applied. Users can add more via .ctxignore in their project root.

# Version control
.git/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.eggs/
*.egg-info
*.egg-info/
*.dist-info
*.dist-info/
pip-wheel-metadata/
dist/
build/

# Node.js
node_modules/
.npm/
.yarn/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.obsidian/

# Workspace / agent noise
.claude/
.pytest_cache/
.worktrees/
.tmp/

# Temporary files and directories
tmp/
tmp*/
temp/
*.tmp
*.tmp.*
*.temp
*.bak
*.swx
*.pyc.*

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Environment / secrets
.env
.env.*
*.pem
*.key

# ctx output (don't index your own manifests)
CONTEXT.md

# ctx disk cache
.ctx-cache/

# Google Drive virtual shortcut files (can't be hashed locally)
*.gdoc
*.gsheet
*.gslides
*.gdraw
*.gform
*.gmap
*.gsite

# Binary files are handled by ctx itself: they stay visible in manifests as
# `[binary: ...]` entries and are not sent to the LLM. Add patterns below only
# for files or directories that should be skipped entirely.
